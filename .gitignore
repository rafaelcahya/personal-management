# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
user.json
eventIds.json
feeIds.json
productBrandIds.json
productNameIds.json
tradeIds.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local editor & IDE settings
.vscode/
.claude/settings.local.json

# cypress generated output (HTML reports, screenshots, videos)
cypress/reports/html/
cypress/screenshots/
cypress/videos/

# local assets (screenshots, recordings)
app/assets/*.mp4
app/assets/*.png
app/assets/*.jpg
app/assets/*.gif
app/assets/*.webm
